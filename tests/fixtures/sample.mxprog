; Sample mxprog fixture for checkpoint-driven analysis
SetJointVel(150)
SetJointAcc(150)
SetCartLinVel(5000)
SetCartAcc(600)
SetCartAngVel(1000)
SetBlending(100)

SetCheckpoint(10)

SetWRF(-52.500, -70.000, 60.000, 0.000, 0.000, -90.000)
SetTRF(0.000, 0.000, 90.000, -0.000, 0.000, -0.000)
MovePose(vars.PICK_X, vars.PICK_Y, 30, 180, 0, 0)
SetBlending(0)
SetCartLinVel(vars.SPD_PICK)
MoveLin(vars.PICK_X, vars.PICK_Y, 0, 180, 0, 0)
Delay(vars.GRP_DELAY_OPEN)
SetCartLinVel(vars.SPD_RETRACT)
MoveLin(vars.PICK_X, vars.PICK_Y, 50, 180, 0, 0)
SetBlending(100)

SetCheckpoint(20)

SetWRF(130.000, 175.750, 260.000, -0.000, 0.000, -0.000)
SetTRF(0.000, 0.000, 90.000, -0.000, 0.000, -0.000)
MovePose(30.000, 0.000, 25.000, -90.000, -30.000, -90.000)
MoveLin(0.000, 0.000, 25.000, -90.000, -30.000, -90.000)
SetBlending(0)
SetCartLinVel(vars.SPD_INSERT)
MoveLin(0.000, 0.000, -15.000, -90.000, -30.000, -90.000)
Delay(vars.GRP_DELAY_CLOSE)
SetCartLinVel(vars.SPD_RETRACT)
MoveLin(0.000, 0.000, 25.000, -90.000, -30.000, -90.000)
SetBlending(100)

SetCheckpoint(30)
